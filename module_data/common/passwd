#!/system/bin/sh
# passwd - manage SSH user passwords for ksu-ssh
# Usage: passwd [-1|-6] [root|shell]
#
# Sets or changes the password for SSH users. Passwords are stored as
# SHA-512 crypt ($6$) hashes by default, or MD5 ($1$) with -1.

ALGO=-6
SHADOW_FILE=/data/ssh/etc/shadow

# Parse algorithm flag
case "${1:-}" in
	-1) ALGO=-1; shift ;;
	-6) ALGO=-6; shift ;;
esac

USER=${1:-root}

# Validate username
if [ "$USER" != "root" ] && [ "$USER" != "shell" ]; then
	echo "Usage: $0 [-1|-6] [root|shell]"
	echo ""
	echo "  -1     Use MD5 ($1$) hashing (default: SHA-512 $6$)"
	echo "  root   Set password for the root SSH user (UID 0)"
	echo "  shell  Set password for the shell SSH user (UID 2000)"
	exit 1
fi

# Ensure shadow infrastructure exists
mkdir -p /data/ssh/etc
if [ ! -f "$SHADOW_FILE" ]; then
	touch "$SHADOW_FILE"
	chmod 600 "$SHADOW_FILE"
fi

# Interactive password prompt with confirmation
echo -n "Enter password for $USER: "
stty -echo 2>/dev/null
read PASSWD
stty echo 2>/dev/null
echo ""

if [ -z "$PASSWD" ]; then
	echo "Error: password cannot be empty."
	exit 1
fi

echo -n "Confirm password for $USER: "
stty -echo 2>/dev/null
read PASSWD2
stty echo 2>/dev/null
echo ""

if [ "$PASSWD" != "$PASSWD2" ]; then
	echo "Error: passwords do not match."
	exit 1
fi

# Generate crypt hash (SHA-512 by default, MD5 with -1)
HASH=$(printf '%s' "$PASSWD" | openssl passwd $ALGO -stdin 2>/dev/null)

if [ -z "$HASH" ]; then
	echo "Error: password hashing failed."
	exit 1
fi

# Atomic update of shadow file
if grep -q "^$USER:" "$SHADOW_FILE" 2>/dev/null; then
	sed -i "s|^$USER:.*|$USER:$HASH:::::::|" "$SHADOW_FILE"
else
	echo "$USER:$HASH:::::::" >> "$SHADOW_FILE"
fi

chmod 600 "$SHADOW_FILE"
echo "Password for $USER updated successfully."
echo ""
echo "Note: You must re-run passwd after reinstalling the module."
